# ── .NET / BepInEx mod build output ──
mod/**/bin/
mod/**/obj/
*.user
*.suo
.vs/

# ── Game reference DLLs — do NOT redistribute; resolved locally at build time ──
mod/lib/
*.dll

# ── Decompiler / scratch output ──
decompiled/
*.il

# ── Thunderstore build artifact (rebuilt from source by thunderstore/build.ps1 or tcli) ──
thunderstore/*.zip
thunderstore/.stage/
thunderstore/build/

# ── IDE / editor ──
.idea/
*.swp

# ── OS cruft ──
.DS_Store
Thumbs.db
desktop.ini
